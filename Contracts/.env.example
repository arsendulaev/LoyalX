# TON network: "mainnet" or "testnet"
NETWORK=testnet

# API key for toncenter.com (optional, raises rate limits)
TONCENTER_API_KEY=

# Address of the deployed Factory contract (used by deploy/agent scripts)
VITE_FACTORY_ADDRESS=

# Mnemonic of the deployer wallet (24 words, space-separated). Keep secret.
WALLET_MNEMONIC=
WALLET_VERSION=v4
